# ─── PostgreSQL ───
POSTGRES_USER=accounting
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=accounting
POSTGRES_PORT=5432

# ─── Adminer ───
ADMINER_PORT=8080

# ─── API (.NET) ───
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8081

# ─── JWT ───
JWT_SECRET=replace_with_at_least_32_char_random_secret_value_here
JWT_ISSUER=accounting-api
JWT_AUDIENCE=accounting-web
JWT_EXPIRY_MINUTES=60

# ─── Web (Next.js) ───
NEXT_PUBLIC_API_URL=http://localhost:8081
API_INTERNAL_URL=http://localhost:8081
WEB_PORT=3000
